# Real queues and DM copy must never be committed.
queue.json
queue.*.json
!skills/*/templates/queue.example.json
dm-message.md
dm-message.*.md
!skills/*/templates/dm-message.example.md

# Lark credentials and token cache.
lark_config.json
.lark_tokens.json

# Product Hunt token cache.
.ph_tokens.json

# Luma admin API cookies + event id pinned at home dir.
.luma_cookie
.luma_event_id

# Brevo / generic env files.
.env
.env.local
.env.*.local

# Brevo per-run output dirs (created by run_brevo_email.py).
brevo-output/
yinch-auto-mkt-output/

# Real request files (keep only *.example.json under templates/).
*_request.json
!skills/*/templates/*.example.json

# Blog drafts and image bundles the user keeps next to the lark-blog skill.
*_draft.md
*_launch.md
blog-images/
!skills/lark-blog/templates/**

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Local notes
.local/
scratch/
