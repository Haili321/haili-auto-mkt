# Real queues and DM copy must never be committed.
queue.json
queue.*.json
!skills/*/templates/queue.example.json
dm-message.md
dm-message.*.md
!skills/*/templates/dm-message.example.md

# Lark credentials and token cache.
lark_config.json
.lark_tokens.json

# Product Hunt token cache.
.ph_tokens.json

# Brevo / generic env files.
.env
.env.local
.env.*.local

# Brevo per-run output dirs (created by run_brevo_email.py).
brevo-output/
yinch-auto-mkt-output/

# Real request files (keep only *.example.json under examples/).
*_request.json
!skills/*/examples/*.example.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp

# Local notes
.local/
scratch/
